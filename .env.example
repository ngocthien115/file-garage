# File Garage - Environment Variables
# Copy file này thành .env và điền giá trị thực

# === BẮT BUỘC ===
GCS_BUCKET=your-bucket-name
GCS_PROJECT_ID=your-gcp-project-id
TOTP_SECRET=YOUR_BASE32_SECRET_HERE
# Tạo secret mới: python3 -c "import pyotp; print(pyotp.random_base32())"
# KHÔNG dùng secret mẫu trong production!

# === TÙY CHỌN ===
PORT=8080
DB_PATH=/tmp/file-garage.db
# DB_PATH là đường dẫn đến file SQLite lưu metadata (filename, size, TTL...).
# Mặc định /tmp/ sẽ bị xoá khi container restart — đúng với thiết kế lưu trữ tạm thời.

# Service account key (chỉ cần khi chạy local, Cloud Run dùng Workload Identity)
GOOGLE_APPLICATION_CREDENTIALS=/path/to/sa-key.json

# GitHub repo chứa fg-cli install scripts (dùng cho endpoint /install)
# Định dạng: owner/repo
GITHUB_REPO=YOUR_USER/file-garage

# Branch chứa fg-cli/install.sh và fg-cli/install.ps1
GITHUB_BRANCH=main
